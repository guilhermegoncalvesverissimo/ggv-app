# ──────────────────────────────────────────────────────────────────────────────
# News backend (used by /api/news + /api/mcp + Notícias feed)
# Both Supabase vars are required for posts to persist. Without them, the API
# returns a "storage_not_configured" hint and the Notícias tab shows an
# explanatory empty-state.
# ──────────────────────────────────────────────────────────────────────────────

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Bearer token expected by /api/news (POST) and /api/mcp. Generate with:
#   openssl rand -hex 32
MCP_BEARER_TOKEN=
